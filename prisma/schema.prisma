generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  imageUrl    String?
  category    String   @default("Uncategorized")
  published   Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sticky      Boolean  @default(false)

  @@map("blog_posts")
}

model FaqItem {
  id       String @id @default(cuid())
  question String
  answer   String
  order    Int    @default(0)

  @@map("faq_items")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

model SiteSettings {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("site_settings")
}
